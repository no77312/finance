{
  "name": "position-circle-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node test/run-api-tests.js",
    "test:advice": "node test/group-advice-score.test.mjs",
    "test:telegram": "node test/telegram-digest.test.mjs && node test/telegram-webhook.test.mjs",
    "telegram:set-webhook": "node scripts/set-telegram-webhook.mjs",
    "web:install": "npm --prefix web install",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "google-auth-library": "^10.4.1"
  }
}
